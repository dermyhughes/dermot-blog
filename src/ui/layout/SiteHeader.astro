---
import ThemeToggle from '../navigation/ThemeToggle';
import Navigation from '../navigation/Navigation.astro';
import SocialLinks from '../navigation/SocialLinks.astro';
import type { GhostSettings } from '../../lib/ghost-types';

interface Props {
  settings: GhostSettings;
  currentPath: string;
  isHome?: boolean;
}

const { settings, currentPath, isHome = false } = Astro.props;
---

<header class='site-head' data-home={isHome ? 'true' : undefined}>
  <div class='container site-head-inner'>
    <a class='site-wordmark' href='/' aria-label={`${settings.title} — home`}>
      <span class='site-wordmark-text'>{settings.title}</span><span
        class='site-wordmark-cursor'
        aria-hidden='true'>_</span
      >
    </a>

    <nav class='site-nav' aria-label='Primary navigation'>
      <Navigation
        data={settings.navigation || []}
        navClass='site-nav-item'
        currentPath={currentPath}
        withIndex
      />
    </nav>

    <div class='site-actions' role='group' aria-label='Display and social links'>
      <SocialLinks />
      <span class='site-actions-divider' aria-hidden='true'></span>
      <ThemeToggle client:load />
    </div>
  </div>
</header>

<style lang='scss'>
  .site-head {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background: var(--glass-bg);
    border-bottom: 1px solid var(--glass-border);
    backdrop-filter: blur(var(--blur-glass)) saturate(1.5);
    -webkit-backdrop-filter: blur(var(--blur-glass)) saturate(1.5);
    /* Own transition group — the chrome stays put while page content
       morphs during cross-document view transitions */
    view-transition-name: site-head;
  }

  /* Bar starts transparent and frosts over as you scroll —
     progressive enhancement via scroll-driven animations */
  @supports (animation-timeline: scroll()) {
    @media (prefers-reduced-motion: no-preference) {
      .site-head {
        animation: site-head-frost linear both;
        animation-timeline: scroll();
        animation-range: 0 160px;
      }
    }
  }

  @keyframes site-head-frost {
    from {
      background: transparent;
      border-bottom-color: transparent;
      backdrop-filter: blur(0) saturate(1);
      -webkit-backdrop-filter: blur(0) saturate(1);
    }

    to {
      background: var(--glass-bg);
      border-bottom-color: var(--glass-border);
      backdrop-filter: blur(var(--blur-glass)) saturate(1.5);
      -webkit-backdrop-filter: blur(var(--blur-glass)) saturate(1.5);
    }
  }

  .site-head-inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    min-height: var(--header-height);
  }

  .site-wordmark {
    display: inline-flex;
    align-items: baseline;
    font-family: var(--font-family-display);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-display);
    color: var(--color-text-strong);
    white-space: nowrap;

    &:hover {
      text-decoration: none;
      color: var(--color-text-strong);
    }
  }

  .site-wordmark-cursor {
    color: var(--color-accent-text);
    margin-left: 0.15em;
    font-weight: var(--font-weight-black);
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-wordmark:hover .site-wordmark-cursor {
      animation: wordmark-blink 1s steps(2, start) infinite;
    }
  }

  @keyframes wordmark-blink {
    to {
      visibility: hidden;
    }
  }

  .site-nav {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
    margin-left: var(--space-lg);
    overflow-x: auto;
    scrollbar-width: none;

    &::-webkit-scrollbar {
      display: none;
    }
  }

  .site-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-left: auto;
  }

  .site-actions-divider {
    width: 1px;
    height: 2rem;
    background: var(--color-border-subtle);
  }

  @media (max-width: 680px) {
    .site-head-inner {
      gap: var(--space-sm);
    }

    .site-nav {
      margin-left: var(--space-2xs);
      mask-image: linear-gradient(90deg, black 85%, transparent);
    }

    .site-nav :global(.site-nav-index) {
      display: none;
    }

    .site-actions :global(.social-container),
    .site-actions-divider {
      display: none;
    }
  }
</style>
