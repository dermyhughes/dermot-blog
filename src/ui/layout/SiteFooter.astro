---
import Icon from '../icons/Icon.astro';
import Navigation from '../navigation/Navigation.astro';
import SocialLinks from '../navigation/SocialLinks.astro';
import type { GhostSettings } from '../../lib/ghost-types';

interface Props {
  settings: GhostSettings;
  currentPath: string;
  currentYear: number;
}

const { settings, currentPath, currentYear } = Astro.props;
---

<footer class='site-foot'>
  <div class='container'>
    <div class='site-foot-grid'>
      <div class='site-foot-brand'>
        <a class='site-foot-wordmark' href='/'>
          {settings.title}<span aria-hidden='true'>_</span>
        </a>
        {settings.description && <p class='site-foot-tagline'>{settings.description}</p>}
      </div>

      <nav class='site-foot-nav' aria-label='Footer navigation'>
        <p class='spec-label site-foot-heading'>[ navigate ]</p>
        <Navigation
          data={settings.navigation || []}
          navClass='site-foot-nav-item'
          currentPath={currentPath}
        />
      </nav>

      <div class='site-foot-connect'>
        <p class='spec-label site-foot-heading'>[ connect ]</p>
        <div class='site-foot-social'>
          <SocialLinks label='Footer social links' />
          <a class='site-foot-rss' href='/rss/' aria-label='RSS feed' title='RSS feed'>
            <Icon name='rss' class='site-foot-rss-icon' />
          </a>
        </div>
      </div>
    </div>

    <div class='site-foot-bottom'>
      <span class='spec-label'>© {currentYear} — <b>{settings.title}</b></span>
      <span class='spec-label site-foot-colophon'>built with astro × ghost</span>
      <a class='spec-label site-foot-top' href='#top'>
        <span aria-hidden='true'>^</span> back to top
      </a>
    </div>
  </div>
</footer>

<style lang='scss'>
  .site-foot {
    position: relative;
    padding: var(--space-3xl) 0 var(--space-xl);
    font-size: var(--text-sm);

    /* Horizon hairline */
    &::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent,
        var(--color-accent) 35%,
        var(--color-accent-2) 65%,
        transparent
      );
      opacity: 0.45;
    }
  }

  .site-foot-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .site-foot-wordmark {
    display: inline-block;
    font-family: var(--font-family-display);
    font-size: var(--display-sm);
    font-weight: var(--font-weight-black);
    letter-spacing: var(--letter-spacing-display);
    color: var(--color-text-strong);

    span {
      color: var(--color-accent-text);
    }

    &:hover {
      text-decoration: none;
      color: var(--color-text-strong);
    }
  }

  .site-foot-tagline {
    margin: var(--space-sm) 0 0;
    max-width: 36rem;
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    text-wrap: pretty;
  }

  .site-foot-heading {
    margin: 0 0 var(--space-sm);
  }

  .site-foot-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .site-foot-nav :global(.site-foot-nav-item) {
    display: inline-block;
    padding: var(--space-3xs) 0;
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);

    &:hover {
      color: var(--color-accent-text);
      text-decoration: none;
    }

    &:global(.active-link) {
      color: var(--color-text-strong);
    }
  }

  .site-foot-social {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  .site-foot-rss {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    transition:
      color var(--transition-fast),
      filter var(--transition-fast);

    &:hover {
      color: var(--color-accent-text);
      filter: drop-shadow(0 0 8px var(--color-accent));
    }
  }

  /* The icon svg renders inside the Icon component, outside this
     component's scope — reach it through the scoped parent */
  .site-foot-rss :global(.site-foot-rss-icon) {
    width: 1.7rem;
    height: 1.7rem;
  }

  .site-foot-bottom {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border-subtle);

    .spec-label {
      margin: 0;
    }
  }

  .site-foot-top {
    color: var(--color-accent-text);

    &:hover {
      color: var(--color-link-hover);
      text-decoration: none;
    }
  }

  @media (max-width: 980px) {
    .site-foot-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .site-foot-bottom {
      flex-wrap: wrap;
    }

    .site-foot-colophon {
      order: 3;
      width: 100%;
    }
  }
</style>
