---
interface Props {
  title: string;
  description?: string | null;
  count?: number | null;
}

const { title, description = null, count = null } = Astro.props;
---

<header class='tag-header'>
  <p class='spec-label'>
    [ tag archive {count !== null && <b>/ {String(count).padStart(3, '0')} entries</b>} ]
  </p>
  <h1 class='tag-header-title'>{title}</h1>
  {description ? <p class='tag-header-desc'>{description}</p> : null}
</header>

<style lang='scss'>
  .tag-header {
    max-width: 76rem;
    margin: 0 0 var(--space-2xl);

    .spec-label {
      margin: 0 0 var(--space-sm);
    }
  }

  .tag-header-title {
    margin: 0 0 var(--space-sm);
    font-size: var(--display-xl);
    font-weight: var(--font-weight-black);
    line-height: var(--leading-tight);
    letter-spacing: var(--letter-spacing-display);
    text-transform: lowercase;
    color: var(--color-text-strong);
    text-shadow:
      -0.025em 0.012em 0 color-mix(in srgb, var(--color-accent) 45%, transparent),
      0.025em -0.012em 0 color-mix(in srgb, var(--color-accent-2) 38%, transparent);

    &::after {
      content: '/';
      margin-left: 0.2em;
      color: var(--color-accent-text);
      font-weight: var(--font-weight-normal);
      text-shadow: none;
    }
  }

  .tag-header-desc {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    max-width: 56rem;
    text-wrap: pretty;
  }
</style>
