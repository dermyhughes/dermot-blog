---
import SocialLinks from '../navigation/SocialLinks.astro';

interface Props {
  title: string;
  descriptionParts: string[];
}

const { title, descriptionParts } = Astro.props;

// The marquee roster — every hat worn, in increasing order of honesty.
const marqueeRoles = [
  'front-end web developer',
  'designer',
  'ux engineer',
  'design systems engineer',
  'pixel pusher',
  'interface architect',
  'component librarian',
  'accessibility advocate',
  'css whisperer',
  'token wrangler',
  'keyframe choreographer',
  'semantic html purist',
  'gradient gardener',
  'professional div aligner',
];

// Two identical groups make the loop seamless; each group is repeated
// wide enough to always exceed the viewport, so the track never runs dry.
const marqueeGroup = Array.from({ length: 2 }).flatMap(() => marqueeRoles);
---

<section class='site-banner' aria-labelledby='site-banner-title'>
  <div class='site-banner-floor' aria-hidden='true'></div>
  <div class='site-banner-horizon' aria-hidden='true'></div>

  <span class='site-banner-annotation site-banner-annotation--left spec-label' aria-hidden='true'>
    [ index <b>/ 001</b> ]
  </span>
  <span class='site-banner-annotation site-banner-annotation--right spec-label' aria-hidden='true'>
    [ v3.0 — <b>vapour</b> ]
  </span>

  <div class='site-banner-stage container'>
    <h1 id='site-banner-title' class='site-banner-title' data-line={title}>
      {title}
    </h1>

    {
      descriptionParts.length > 0 && (
        <p class='site-banner-desc'>
          {descriptionParts.map((item, index) => (
            <>
              <span class='site-banner-desc-part'>{item}</span>
              {index < descriptionParts.length - 1 && (
                <span class='site-banner-desc-sep' aria-hidden='true'>
                  /
                </span>
              )}
            </>
          ))}
        </p>
      )
    }

    <div class='site-banner-social'>
      <SocialLinks isHome />
    </div>
  </div>

  <div class='site-banner-scroll spec-label' aria-hidden='true'>scroll</div>

  <div class='site-marquee' aria-hidden='true'>
    <div class='site-marquee-track'>
      <span class='site-marquee-group'>
        {marqueeGroup.map((item) => (
          <span class='site-marquee-item'>
            {item}
            <span class='site-marquee-star'>✦</span>
          </span>
        ))}
      </span>
      <span class='site-marquee-group'>
        {marqueeGroup.map((item) => (
          <span class='site-marquee-item'>
            {item}
            <span class='site-marquee-star'>✦</span>
          </span>
        ))}
      </span>
    </div>
  </div>
</section>

<style lang='scss'>
  .site-banner {
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(92svh - var(--header-height));
    padding: var(--space-3xl) 0 var(--space-4xl);
    overflow: clip;
  }

  /* Perspective grid floor — the synthwave stage */
  .site-banner-floor {
    position: absolute;
    left: -12%;
    right: -12%;
    bottom: -4rem;
    height: 46%;
    z-index: -2;
    background-image:
      repeating-linear-gradient(
        90deg,
        var(--grid-line) 0 1px,
        transparent 1px 7rem
      ),
      repeating-linear-gradient(0deg, var(--grid-line) 0 1px, transparent 1px 5rem);
    transform: perspective(56rem) rotateX(58deg);
    transform-origin: 50% 0;
    mask-image: linear-gradient(to bottom, transparent 0, black 18%, black 72%, transparent 100%);
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-banner-floor {
      animation: floor-travel 2.6s linear infinite;
    }
  }

  @keyframes floor-travel {
    to {
      background-position:
        0 0,
        0 5rem;
    }
  }

  /* Glowing horizon hairline where the floor meets the haze */
  .site-banner-horizon {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 46%;
    height: 1px;
    z-index: -1;
    background: linear-gradient(
      90deg,
      transparent 4%,
      var(--color-accent) 30%,
      var(--color-accent-2) 70%,
      transparent 96%
    );
    opacity: 0.55;
    box-shadow:
      0 0 18px 1px var(--aura-pink),
      0 0 60px 8px var(--aura-pink);
  }

  .site-banner-annotation {
    position: absolute;
    top: var(--space-lg);
    z-index: 1;
    white-space: nowrap;

    &--left {
      left: var(--layout-gutter);
    }

    &--right {
      right: var(--layout-gutter);
    }
  }

  .site-banner-stage {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: var(--space-lg);
  }

  /* The display title with chromatic-aberration ghosts */
  .site-banner-title {
    position: relative;
    z-index: 0;
    margin: 0;
    max-width: 100%;
    font-family: var(--font-family-display);
    font-size: var(--display-2xl);
    font-weight: var(--font-weight-black);
    font-optical-sizing: auto;
    line-height: var(--leading-tight);
    letter-spacing: var(--letter-spacing-display);
    text-transform: uppercase;
    text-wrap: balance;
    color: var(--color-text-strong);

    &::before,
    &::after {
      content: attr(data-line);
      position: absolute;
      inset: 0;
      backface-visibility: hidden;
      pointer-events: none;
      user-select: none;
    }

    /* Pink ghost — shifted left, softly blurred */
    &::before {
      z-index: -1;
      color: var(--color-accent);
      opacity: 0.8;
      filter: blur(2px);
      transform: translate3d(-0.045em, 0.01em, 0);
    }

    /* Cyan ghost — shifted right */
    &::after {
      z-index: -2;
      color: var(--color-accent-2);
      opacity: 0.7;
      filter: blur(3px);
      transform: translate3d(0.045em, -0.01em, 0);
    }
  }

  .site-banner-desc {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    column-gap: var(--space-sm);
    row-gap: var(--space-3xs);
    margin: 0;
    max-width: 64rem;
    font-size: clamp(1.6rem, 1.3rem + 1vw, 2.2rem);
    line-height: var(--leading-snug);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    text-wrap: balance;
  }

  .site-banner-desc-sep {
    font-family: var(--font-family-mono);
    color: var(--color-accent-text);
    font-size: 0.8em;
  }

  .site-banner-social {
    margin-top: var(--space-sm);
  }

  .site-banner-scroll {
    position: absolute;
    bottom: calc(var(--space-2xl) + 4.4rem);
    left: 50%;
    translate: -50% 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);

    &::after {
      content: '';
      width: 1px;
      height: 4rem;
      background: linear-gradient(to bottom, var(--color-accent), transparent);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-banner-scroll::after {
      animation: scroll-cue 2.2s var(--ease-in-out-soft) infinite;
    }
  }

  @keyframes scroll-cue {
    0% {
      transform: scaleY(0);
      transform-origin: top;
    }

    45% {
      transform: scaleY(1);
      transform-origin: top;
    }

    55% {
      transform: scaleY(1);
      transform-origin: bottom;
    }

    100% {
      transform: scaleY(0);
      transform-origin: bottom;
    }
  }

  /* Marquee strip — duplicated description, purely decorative */
  .site-marquee {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
    border-block: 1px solid var(--color-border-subtle);
    background: var(--glass-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--space-xs) 0;
  }

  .site-marquee-track {
    display: flex;
    width: max-content;
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-marquee-track {
      animation: marquee-roll 90s linear infinite;
    }
  }

  .site-marquee-group {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .site-marquee-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-lg);
    padding-right: var(--space-lg);
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--letter-spacing-mono);
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--color-text-muted);
  }

  .site-marquee-star {
    color: var(--color-accent-text);
    font-size: 0.9em;
  }

  @keyframes marquee-roll {
    to {
      transform: translateX(-50%);
    }
  }

  /* Load choreography — one staged reveal, then calm */
  @media (prefers-reduced-motion: no-preference) {
    .site-banner-title {
      animation: rise-in 900ms var(--ease-out-expo) both;
    }

    .site-banner-title::before {
      animation:
        ca-settle-pink 700ms var(--ease-out-expo) 500ms both,
        ca-drift-pink 9s steps(1, end) 3s infinite;
    }

    .site-banner-title::after {
      animation:
        ca-settle-cyan 700ms var(--ease-out-expo) 560ms both,
        ca-drift-cyan 9s steps(1, end) 3s infinite;
    }

    .site-banner-desc {
      animation: rise-in 800ms var(--ease-out-expo) 350ms both;
    }

    .site-banner-social {
      animation: rise-in 800ms var(--ease-out-expo) 500ms both;
    }

    .site-banner-annotation {
      animation: fade-in 900ms linear 900ms both;
    }

    .site-banner-scroll {
      animation: fade-in 900ms linear 1200ms both;
    }

    .site-banner-horizon {
      animation: horizon-ignite 1400ms var(--ease-out-expo) 700ms both;
    }
  }

  @keyframes rise-in {
    from {
      opacity: 0;
      transform: translateY(2.4rem);
      filter: blur(6px);
    }

    to {
      opacity: 1;
      transform: none;
      filter: blur(0);
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes horizon-ignite {
    from {
      opacity: 0;
      transform: scaleX(0.2);
    }

    to {
      opacity: 0.55;
      transform: none;
    }
  }

  /* Ghosts slide out from behind the title once it lands */
  @keyframes ca-settle-pink {
    from {
      opacity: 0;
      transform: translate3d(0, 0, 0);
      filter: blur(0);
    }

    to {
      opacity: 0.8;
      transform: translate3d(-0.045em, 0.01em, 0);
      filter: blur(2px);
    }
  }

  @keyframes ca-settle-cyan {
    from {
      opacity: 0;
      transform: translate3d(0, 0, 0);
      filter: blur(0);
    }

    to {
      opacity: 0.7;
      transform: translate3d(0.045em, -0.01em, 0);
      filter: blur(3px);
    }
  }

  /* Occasional mis-registration twitch — brief, then long idle */
  @keyframes ca-drift-pink {
    0%,
    3.4%,
    100% {
      transform: translate3d(-0.045em, 0.01em, 0);
    }

    0.8% {
      transform: translate3d(-0.075em, 0.022em, 0);
    }

    1.6% {
      transform: translate3d(-0.02em, -0.012em, 0);
    }

    2.4% {
      transform: translate3d(-0.06em, 0.016em, 0);
    }
  }

  @keyframes ca-drift-cyan {
    0%,
    3.4%,
    100% {
      transform: translate3d(0.045em, -0.01em, 0);
    }

    0.8% {
      transform: translate3d(0.08em, -0.024em, 0);
    }

    1.6% {
      transform: translate3d(0.022em, 0.014em, 0);
    }

    2.4% {
      transform: translate3d(0.06em, -0.018em, 0);
    }
  }

  /* Hero recedes into haze as you scroll — scroll-driven, no JS */
  @supports (animation-timeline: scroll()) {
    @media (prefers-reduced-motion: no-preference) {
      .site-banner-stage {
        animation: hero-recede linear both;
        animation-timeline: scroll();
        animation-range: 0 88svh;
      }
    }
  }

  @keyframes hero-recede {
    to {
      opacity: 0.1;
      transform: translateY(-5rem) scale(0.97);
      filter: blur(10px);
    }
  }

  @media (max-width: 680px) {
    .site-banner {
      min-height: calc(86svh - var(--header-height));
      padding-top: var(--space-2xl);
    }

    .site-banner-annotation--right {
      display: none;
    }

    .site-banner-scroll {
      display: none;
    }
  }
</style>
