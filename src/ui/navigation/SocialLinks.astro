---
import Icon from '../icons/Icon.astro';
import type { IconName } from '../icons/registry';

interface Props {
  isHome?: boolean;
  label?: string;
}

const { isHome = false, label = 'Social links' } = Astro.props;

const socialLinks: Array<{ href: string; icon: IconName; alt: string }> = [
  {
    href: 'https://github.com/dermyhughes',
    icon: 'github',
    alt: 'GitHub',
  },
  {
    href: 'https://www.linkedin.com/in/dermot-hughes-a96b67b6',
    icon: 'linkedin',
    alt: 'LinkedIn',
  },
];
---

<nav class={`social-container ${isHome ? 'social-container--hero' : ''}`} aria-label={label}>
  {
    socialLinks.map((link) => (
      <a
        class='social-link'
        href={link.href}
        target='_blank'
        rel='noopener noreferrer'
        aria-label={link.alt}
        title={link.alt}
      >
        <Icon name={link.icon} class='social-icon' />
      </a>
    ))
  }
</nav>

<style lang='scss'>
  .social-container {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    transition:
      color var(--transition-fast),
      filter var(--transition-fast),
      transform var(--transition-fast);

    &:hover {
      color: var(--color-accent-text);
      filter: drop-shadow(0 0 8px var(--color-accent));
      transform: translateY(-2px);
    }
  }

  /* The icon svg renders inside the Icon component, outside this
     component's scope — reach it through the scoped parent */
  .social-link :global(.social-icon) {
    width: 1.8rem;
    height: 1.8rem;
  }

  .social-container--hero {
    gap: var(--space-sm);

    .social-link {
      width: 4.4rem;
      height: 4.4rem;
      color: var(--color-text-primary);
      border: 1px solid var(--color-border-strong);
      background: var(--glass-bg);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);

      &:hover {
        color: var(--color-accent-text);
        border-color: var(--color-accent);
        box-shadow: var(--glow-pink);
        filter: none;
      }
    }

    .social-link :global(.social-icon) {
      width: 2rem;
      height: 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .social-link {
      transition: none;

      &:hover {
        transform: none;
      }
    }
  }
</style>
