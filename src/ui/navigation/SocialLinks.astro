---
interface Props {
  isHome?: boolean;
  label?: string;
}

const { isHome = false, label = 'Social links' } = Astro.props;

const socialLinks = [
  {
    href: 'https://github.com/dermyhughes',
    icon: 'github',
    alt: 'GitHub',
  },
  {
    href: 'https://www.linkedin.com/in/dermot-hughes-a96b67b6',
    icon: 'linkedin',
    alt: 'LinkedIn',
  },
];

const iconPaths: Record<string, string> = {
  github:
    'M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z',
  linkedin:
    'M13.63 13.63h-2.37v-3.71c0-.89-.02-2.03-1.24-2.03-1.24 0-1.43.97-1.43 1.96v3.78H6.22V6h2.28v1.04h.03c.32-.6 1.09-1.23 2.25-1.23 2.4 0 2.85 1.58 2.85 3.64v4.18ZM3.56 4.95a1.38 1.38 0 1 1 0-2.75 1.38 1.38 0 0 1 0 2.75Zm1.19 8.68H2.37V6h2.38v7.63ZM14.81 0H1.18C.53 0 0 .52 0 1.15v13.7C0 15.48.53 16 1.18 16h13.63c.65 0 1.19-.52 1.19-1.15V1.15C16 .52 15.46 0 14.81 0Z',
};
---

<nav class={`social-container ${isHome ? 'social-container--hero' : ''}`} aria-label={label}>
  {
    socialLinks.map((link) => (
      <a
        class='social-link'
        href={link.href}
        target='_blank'
        rel='noopener noreferrer'
        aria-label={link.alt}
        title={link.alt}
      >
        <svg
          class='social-icon'
          viewBox='0 0 16 16'
          fill='currentColor'
          aria-hidden='true'
          focusable='false'
        >
          <path d={iconPaths[link.icon]} />
        </svg>
      </a>
    ))
  }
</nav>

<style lang='scss'>
  .social-container {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    transition:
      color var(--transition-fast),
      filter var(--transition-fast),
      transform var(--transition-fast);

    &:hover {
      color: var(--color-accent-text);
      filter: drop-shadow(0 0 8px var(--color-accent));
      transform: translateY(-2px);
    }
  }

  .social-icon {
    width: 1.8rem;
    height: 1.8rem;
  }

  .social-container--hero {
    gap: var(--space-sm);

    .social-link {
      width: 4.4rem;
      height: 4.4rem;
      color: var(--color-text-primary);
      border: 1px solid var(--color-border-strong);
      background: var(--glass-bg);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);

      &:hover {
        color: var(--color-accent-text);
        border-color: var(--color-accent);
        box-shadow: var(--glow-pink);
        filter: none;
      }
    }

    .social-icon {
      width: 2rem;
      height: 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .social-link {
      transition: none;

      &:hover {
        transform: none;
      }
    }
  }
</style>
