---
import type { GhostPost } from '../../lib/ghost-types';
import { formatPostDate, formatReadingTime, getPostPath, getPublicTags, padIndex } from '../../lib/content';
import getPostTransitionName from '../../lib/transitions';
import { buildGhostSrcset } from '../../lib/images';

interface Props {
  post: GhostPost;
  index?: number;
  variant?: 'grid' | 'feature';
}

const { post, index = 1, variant = 'grid' } = Astro.props;

const url = getPostPath(post);
const publicTags = getPublicTags(post.tags);
const primaryTag = publicTags[0] || null;
const excerpt = post.excerpt || post.custom_excerpt || '';
const readingTime = formatReadingTime(post);
const indexLabel = padIndex(index);
const publishedDate = formatPostDate(post.published_at);

const isFeature = variant === 'feature';
const imageSrcset = buildGhostSrcset(post.feature_image);
const imageSizes = isFeature
  ? '(max-width: 980px) 100vw, 640px'
  : '(max-width: 680px) 100vw, (max-width: 980px) 92vw, 560px';
const transitionName = getPostTransitionName(post);
---

<a href={url} class={`post-card ${variant === 'feature' ? 'post-card--feature' : ''}`}>
  <span class='post-card-corner post-card-corner--tl' aria-hidden='true'></span>
  <span class='post-card-corner post-card-corner--br' aria-hidden='true'></span>

  <div class='post-card-media' style={`view-transition-name: ${transitionName};`}>
    {
      post.feature_image ? (
        <img
          class='post-card-image'
          src={post.feature_image}
          srcset={imageSrcset}
          sizes={imageSrcset ? imageSizes : undefined}
          alt=''
          loading={isFeature ? 'eager' : 'lazy'}
          fetchpriority={isFeature ? 'high' : undefined}
          decoding='async'
        />
      ) : (
        <div class='post-card-placeholder' aria-hidden='true'>
          <span class='post-card-placeholder-index'>{indexLabel}</span>
        </div>
      )
    }
    {
      (primaryTag || post.featured) && (
        <div class='post-card-chips'>
          {post.featured && <span class='post-card-chip post-card-chip--featured'>featured</span>}
          {primaryTag && <span class='post-card-chip'>{primaryTag.name}</span>}
        </div>
      )
    }
  </div>

  <div class='post-card-body'>
    <p class='post-card-meta spec-label'>
      <b>[ {indexLabel} ]</b>
      {publishedDate && <span class='post-card-meta-item'>{publishedDate}</span>}
      <span class='post-card-meta-item'>{readingTime}</span>
    </p>

    <h2 class='post-card-title'>{post.title}</h2>

    {excerpt && <p class='post-card-excerpt'>{excerpt}</p>}

    <span class='post-card-cta spec-label'>
      read entry <span class='post-card-cta-arrow' aria-hidden='true'>-&gt;</span>
    </span>
  </div>
</a>

<style lang='scss'>
  @use '../styles/mixins' as mix;

  .post-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: var(--space-sm);

    @include mix.raised-card;
  }

  /* Crop-mark corners — appear on hover, spec-sheet style */
  .post-card-corner {
    position: absolute;
    width: 1.4rem;
    height: 1.4rem;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity var(--transition-medium),
      transform var(--transition-medium);

    &--tl {
      top: 0.6rem;
      left: 0.6rem;
      border-top: 2px solid var(--color-accent);
      border-left: 2px solid var(--color-accent);
      transform: translate(0.4rem, 0.4rem);
    }

    &--br {
      bottom: 0.6rem;
      right: 0.6rem;
      border-bottom: 2px solid var(--color-accent-2);
      border-right: 2px solid var(--color-accent-2);
      transform: translate(-0.4rem, -0.4rem);
    }
  }

  .post-card:hover .post-card-corner {
    opacity: 1;
    transform: none;
  }

  .post-card-media {
    position: relative;
    border-radius: calc(var(--radius-lg) - 0.6rem);
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .post-card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    background-color: var(--color-surface-muted);
    transition:
      transform var(--transition-slow),
      filter var(--transition-slow);
  }

  .post-card:hover .post-card-image {
    transform: scale(1.05);
    filter: saturate(1.25);
  }

  .post-card-placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 20% 20%, var(--aura-pink), transparent 60%),
      radial-gradient(circle at 80% 80%, var(--aura-cyan), transparent 60%),
      var(--color-surface-muted);
  }

  .post-card-placeholder-index {
    font-family: var(--font-family-mono);
    font-size: clamp(4rem, 8vw, 7rem);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-muted);
    opacity: 0.55;
    text-shadow:
      -0.04em 0.015em 1px var(--color-accent),
      0.04em -0.015em 1px var(--color-accent-2);
  }

  .post-card-chips {
    position: absolute;
    top: var(--space-xs);
    left: var(--space-xs);
    display: flex;
    gap: var(--space-2xs);
  }

  .post-card-chip {
    padding: 0.3rem 0.9rem;
    font-family: var(--font-family-mono);
    font-size: var(--text-2xs);
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: var(--color-text-strong);
    background: var(--glass-bg-strong);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-full);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);

    &--featured {
      color: var(--color-accent-text);
      border-color: color-mix(in srgb, var(--color-accent) 55%, transparent);
    }
  }

  .post-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-xs);
    padding: var(--space-md) var(--space-xs) var(--space-2xs);
  }

  .post-card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2xs);
    margin: 0;
  }

  .post-card-meta-item {
    &::before {
      content: '·';
      margin-right: var(--space-2xs);
      color: var(--color-accent-text);
    }
  }

  .post-card-title {
    margin: 0;
    font-size: var(--display-sm);
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-snug);
    letter-spacing: var(--letter-spacing-display);
    color: var(--color-text-strong);
    transition: text-shadow var(--transition-fast);
  }

  /* Chromatic fringe on hover */
  .post-card:hover .post-card-title {
    text-shadow:
      -2px 0 0 color-mix(in srgb, var(--color-accent) 55%, transparent),
      2px 0 0 color-mix(in srgb, var(--color-accent-2) 45%, transparent);
  }

  .post-card-excerpt {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .post-card-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    margin-top: auto;
    padding-top: var(--space-sm);
    color: var(--color-accent-text);
  }

  .post-card-cta-arrow {
    transition: transform var(--transition-medium);
  }

  .post-card:hover .post-card-cta-arrow {
    transform: translateX(0.5rem);
  }

  /* Featured cover card — split editorial layout */
  .post-card--feature {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: var(--space-lg);
    padding: var(--space-md);

    .post-card-media {
      order: 2;
      aspect-ratio: auto;
      min-height: 34rem;
    }

    .post-card-body {
      order: 1;
      justify-content: center;
      padding: var(--space-lg) var(--space-md);
    }

    .post-card-title {
      font-size: var(--display-lg);
      font-weight: var(--font-weight-black);
      line-height: var(--leading-tight);
    }

    .post-card-excerpt {
      -webkit-line-clamp: 4;
      font-size: var(--text-lg);
    }
  }

  /* Entrance — fade up as cards scroll into view (progressive) */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .post-card {
        animation: card-enter linear both;
        animation-timeline: view();
        animation-range: entry 0% entry 60%;
      }
    }
  }

  /* Opacity/blur only — transform stays free for the hover lift,
     since a held animation would override the transition */
  @keyframes card-enter {
    from {
      opacity: 0;
      filter: blur(10px);
    }

    to {
      opacity: 1;
      filter: blur(0);
    }
  }

  @media (max-width: 980px) {
    .post-card--feature {
      grid-template-columns: 1fr;
      gap: var(--space-sm);

      .post-card-media {
        order: 1;
        aspect-ratio: 16 / 10;
        min-height: 0;
      }

      .post-card-body {
        order: 2;
        padding: var(--space-md) var(--space-xs) var(--space-2xs);
      }

      .post-card-title {
        font-size: var(--display-md);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card-image,
    .post-card-cta-arrow,
    .post-card-corner {
      transition: none;
    }

    .post-card:hover .post-card-image {
      transform: none;
    }
  }
</style>
