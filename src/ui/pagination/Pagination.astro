---
import { padIndex } from '../../lib/content';

interface Props {
  previousPagePath?: string;
  nextPagePath?: string;
  humanPageNumber: number;
  numberOfPages: number;
}

const { previousPagePath, nextPagePath, humanPageNumber, numberOfPages } = Astro.props;
---

<nav class='pagination' aria-label='Pagination'>
  <div class='pagination-slot'>
    {
      previousPagePath && (
        <a class='pagination-link' href={previousPagePath} rel='prev'>
          <span aria-hidden='true'>&lt;-</span> prev
        </a>
      )
    }
  </div>
  {
    numberOfPages > 1 && (
      <div class='pagination-location'>
        page <b>{padIndex(humanPageNumber, 2)}</b> <span aria-hidden='true'>/</span> {padIndex(numberOfPages, 2)}
      </div>
    )
  }
  <div class='pagination-slot pagination-slot--end'>
    {
      nextPagePath && (
        <a class='pagination-link' href={nextPagePath} rel='next'>
          next <span aria-hidden='true'>-&gt;</span>
        </a>
      )
    }
  </div>
</nav>

<style lang='scss'>
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
    margin: var(--space-2xl) 0 0;
  }

  .pagination-slot {
    min-width: 9rem;
    display: flex;

    &--end {
      justify-content: flex-end;
    }
  }

  .pagination-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-xs) var(--space-md);
    font-family: var(--font-family-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-full);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);

    &:hover {
      color: var(--color-accent-text);
      border-color: var(--color-accent);
      box-shadow: var(--glow-pink);
      text-decoration: none;
    }
  }

  .pagination-location {
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--letter-spacing-mono);
    text-transform: uppercase;
    color: var(--color-text-muted);

    b {
      color: var(--color-accent-text);
      font-weight: var(--font-weight-normal);
    }
  }
</style>
